{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","abstract":[{"text":"Policy that manages credential rotation by tracking usage count.","type":"text"}],"metadata":{"symbolKind":"case","title":"CredentialPolicy.rotateUse","externalID":"s:18MdocDataModel1801316CredentialPolicyO9rotateUseyA2CmF","modules":[{"name":"MdocDataModel18013"}],"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"rotateUse"}],"roleHeading":"Case"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mdocdatamodel18013\/credentialpolicy\/rotateuse"]}],"sections":[],"identifier":{"url":"doc:\/\/MdocDataModel18013\/documentation\/MdocDataModel18013\/CredentialPolicy\/rotateUse","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"rotateUse"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"When a credential is used, its usage count is incremented, allowing the system to distribute load across multiple available credentials. This approach balances"},{"type":"text","text":" "},{"type":"text","text":"security with performance considerations by enabling credential reuse while maintaining usage patterns for auditing and optimization purposes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Appropriate for scenarios requiring frequent authentication where the performance overhead of continuous credential generation would be prohibitive."},{"type":"text","text":" "},{"type":"text","text":"When ETSI TS 119 472-3 LimitedTime, RotatingBatch, PerRelyingParty reuse methods are applied, the rotateUse credential policy is used."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/MdocDataModel18013\/documentation\/MdocDataModel18013","doc:\/\/MdocDataModel18013\/documentation\/MdocDataModel18013\/CredentialPolicy"]]},"references":{"doc://MdocDataModel18013/documentation/MdocDataModel18013/CredentialPolicy":{"identifier":"doc:\/\/MdocDataModel18013\/documentation\/MdocDataModel18013\/CredentialPolicy","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CredentialPolicy"}],"navigatorTitle":[{"kind":"identifier","text":"CredentialPolicy"}],"kind":"symbol","type":"topic","url":"\/documentation\/mdocdatamodel18013\/credentialpolicy","title":"CredentialPolicy","abstract":[]},"doc://MdocDataModel18013/documentation/MdocDataModel18013/CredentialPolicy/rotateUse":{"identifier":"doc:\/\/MdocDataModel18013\/documentation\/MdocDataModel18013\/CredentialPolicy\/rotateUse","abstract":[{"type":"text","text":"Policy that manages credential rotation by tracking usage count."}],"type":"topic","title":"CredentialPolicy.rotateUse","kind":"symbol","url":"\/documentation\/mdocdatamodel18013\/credentialpolicy\/rotateuse","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"rotateUse","kind":"identifier"}]},"doc://MdocDataModel18013/documentation/MdocDataModel18013":{"identifier":"doc:\/\/MdocDataModel18013\/documentation\/MdocDataModel18013","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/mdocdatamodel18013","title":"MdocDataModel18013","abstract":[]}}}